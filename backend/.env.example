# SnapLink — Environment Variables
# Copy this to .env for local development

# Server
PORT=3000
NODE_ENV=development

# Your public URL (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.onrender.com
BASE_URL=http://localhost:3000

# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/snaplink
# Render:  paste the "Internal Database URL" from Render dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/snaplink

# Optional: Anthropic API key for AI insights
ANTHROPIC_API_KEY=your_key_here
